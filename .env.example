# .env는 선택 사항입니다.
# 파일이 없어도 앱/CLI/GUI는 로컬 CLI provider를 자동 탐지해서 실행됩니다.
#
# 자동 탐지 순서:
# 1. codex.cmd
# 2. codex
# 3. gemini.cmd
# 4. gemini
# 5. rule_based fallback
#
# 이 파일은 고급 사용자용 override 예시입니다.
# 필요한 줄만 주석을 풀어 `.env`에 사용하세요.
#
# 모델명은 provider별로 호환되지 않습니다.
# - Codex는 모델을 비워 두면 Codex CLI 기본 모델을 사용합니다.
# - Gemini는 모델을 비워 두면 gemini-2.5-flash를 사용합니다.
# - Gemini provider에는 gpt-* 모델명을 사용하지 마세요.

# 전역 provider override: codex, gemini, rule_based
# LLM_WIKI_AGENT_PROVIDER=codex
# LLM_WIKI_AGENT_PROVIDER=gemini

# role별 provider override
# LLM_WIKI_ANSWER_PROVIDER=gemini
# LLM_WIKI_INGEST_PROVIDER=gemini
# LLM_WIKI_CONCEPT_PROVIDER=gemini
# LLM_WIKI_REVIEW_PROVIDER=gemini

# 모델 override
# Codex 모델을 CLI 기본값으로 두려면 설정하지 마세요.
# LLM_WIKI_AGENT_MODEL=
# LLM_WIKI_ANSWER_MODEL=
# LLM_WIKI_INGEST_MODEL=
# LLM_WIKI_CONCEPT_MODEL=
# LLM_WIKI_REVIEW_MODEL=
#
# Gemini 모델 예시
# LLM_WIKI_AGENT_MODEL=gemini-2.5-flash
# LLM_WIKI_ANSWER_MODEL=gemini-2.5-flash

# CLI command override
# Windows에서 PATH 탐지가 안 되면 .cmd wrapper를 명시할 수 있습니다.
# LLM_WIKI_CODEX_COMMAND=codex.cmd
# LLM_WIKI_GEMINI_COMMAND=gemini.cmd
