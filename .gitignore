__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.runtime/
.venv/
venv/
.env
.env.local

# Raw source privacy boundary. Public-safe samples should live under examples/.
/raw/private/
/raw/**/*.pdf
/raw/**/*.zip
/raw/**/*.png
/raw/**/*.jpg
/raw/**/*.jpeg
/raw/**/*.gif
/raw/**/*.webp
/raw/**/*.html
/raw/**/*.htm
/raw/**/*.env
/raw/**/*.key

# Example raw folders may only contain public-safe text fixtures.
/examples/**/raw/private/
/examples/**/raw/**/*.pdf
/examples/**/raw/**/*.zip
/examples/**/raw/**/*.png
/examples/**/raw/**/*.jpg
/examples/**/raw/**/*.jpeg
/examples/**/raw/**/*.gif
/examples/**/raw/**/*.webp
/examples/**/raw/**/*.html
/examples/**/raw/**/*.htm
/examples/**/raw/**/*.env
/examples/**/raw/**/*.key

# Local generated state for private domains.
/manifests/
/wiki/

# User domain runtime storage. Keep only the folder marker and local guidance.
/user_domains/*
!/user_domains/.gitkeep
!/user_domains/README.md
